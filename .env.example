# JobSearchOps — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# Legend:
#   REQUIRED — pipeline will fail or silently skip without this
#   OPTIONAL — has a safe default; override only when needed

# ── Adzuna API (source: adzuna-bc) ────────────────────────────────────────────
# Register free at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here        # REQUIRED — Adzuna application ID
ADZUNA_APP_KEY=your_adzuna_app_key_here      # REQUIRED — Adzuna application key

# ── Anthropic API (src/enrich/jd-summarizer.mjs) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here       # REQUIRED — used by AI enrichment / JD summarizer

# ── Capture overrides (src/capture/source-runner.mjs) ─────────────────────────
JOBOPS_SOURCE_SCOPE=                         # OPTIONAL — comma-separated source IDs to run (empty = all enabled)
JOBOPS_MAX_POSTED_DAYS=0                     # OPTIONAL — drop jobs older than N days (0 = no filter)
JOBOPS_LEVEL1_KEYWORDS=                      # OPTIONAL — space-separated keywords, overrides config/keywords.yaml
JOBOPS_EXCLUDED_ANY_KEYWORDS=                # OPTIONAL — space-separated terms, overrides excluded_any list
JOBOPS_EXCLUDED_POST_KEYWORDS=               # OPTIONAL — space-separated terms, overrides excluded_post list
JOBOPS_DISABLE_EXCLUSIONS=0                  # OPTIONAL — set to 1 to disable all keyword exclusions (debug only)

# ── Prompt path override (scripts/jobops-sync-prompt-sources.mjs) ─────────────
JOBOPS_PROMPT_FILE=                          # OPTIONAL — override default prompt .md file path
